<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Job</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <style>
        body{
            background: linear-gradient(135deg,#eef2ff,#dbeafe);
            min-height:100vh;
            display:flex;
            justify-content:center;
            align-items:center;
            padding:40px 0;
        }

        .edit-card{
            width:100%;
            max-width:750px;
            border:none;
            border-radius:20px;
            box-shadow:0 15px 40px rgba(0,0,0,.15);
        }

        .card-header{
            background:#0d6efd;
            color:white;
            text-align:center;
            padding:20px;
            border-radius:20px 20px 0 0;
        }

        .form-control,
        textarea{
            border-radius:10px;
        }

        textarea{
            resize:none;
        }

        .btn-update{
            width:100%;
            padding:12px;
            font-size:18px;
            border-radius:10px;
        }

        .back-link{
            text-decoration:none;
            font-weight:500;
        }

        .back-link:hover{
            text-decoration:underline;
        }

    </style>
</head>
<body>

<div class="card edit-card">

    <div class="card-header">
        <h2><i class="fa-solid fa-pen-to-square"></i> Edit Job</h2>
        <p class="mb-0">Update job information</p>
    </div>

    <div class="card-body p-4">

        <form action="/jobs/<%= job._id %>?_method=PUT" method="POST">

            <div class="mb-3">
                <label class="form-label">
                    <i class="fa-solid fa-briefcase"></i>
                    Job Title
                </label>
                <input
                    type="text"
                    class="form-control"
                    name="title"
                    value="<%= job.title %>"
                    required>
            </div>

            <div class="mb-3">
                <label class="form-label">
                    <i class="fa-solid fa-building"></i>
                    Company
                </label>
                <input
                    type="text"
                    class="form-control"
                    name="company"
                    value="<%= job.company %>"
                    required>
            </div>

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label class="form-label">
                        <i class="fa-solid fa-location-dot"></i>
                        Location
                    </label>
                    <input
                        type="text"
                        class="form-control"
                        name="location"
                        value="<%= job.location %>">
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">
                        <i class="fa-solid fa-indian-rupee-sign"></i>
                        Salary
                    </label>
                    <input
                        type="number"
                        class="form-control"
                        name="salary"
                        value="<%= job.salary %>">
                </div>

            </div>

            <div class="mb-4">
                <label class="form-label">
                    <i class="fa-solid fa-file-lines"></i>
                    Job Description
                </label>
                <textarea
                    class="form-control"
                    rows="6"
                    name="description"
                    required><%= job.description %></textarea>
            </div>

            <button class="btn btn-primary btn-update">
                <i class="fa-solid fa-floppy-disk"></i>
                Update Job
            </button>

        </form>

        <hr>

        <div class="text-center">
            <a href="/jobs" class="back-link">
                <i class="fa-solid fa-arrow-left"></i>
                Back to Job Listings
            </a>
        </div>

    </div>

</div>

</body>
</html>