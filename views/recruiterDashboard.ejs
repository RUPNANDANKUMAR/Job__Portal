<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Recruiter Dashboard</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<style>

body{
    background:#f4f7fc;
}

.navbar{
    box-shadow:0 2px 12px rgba(0,0,0,.08);
}

.card{
    border:none;
    border-radius:18px;
    box-shadow:0 8px 25px rgba(0,0,0,.08);
}

.stat-card{
    text-align:center;
    padding:25px;
}

.stat-card i{
    font-size:35px;
    margin-bottom:10px;
}

.table tbody tr:hover{
    background:#eef5ff;
}

.salary{
    background:#198754;
    color:white;
    padding:6px 12px;
    border-radius:20px;
}

.action-btn{
    margin-right:5px;
}

</style>

</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-primary">

<div class="container">

<a class="navbar-brand fw-bold" href="#">

<i class="fa-solid fa-briefcase"></i>

Job Portal

</a>

<div>

<a href="/jobs/new" class="btn btn-light">

<i class="fa-solid fa-plus"></i>

Post Job

</a>

</div>

</div>

</nav>

<div class="container my-5">

<div class="d-flex justify-content-between align-items-center mb-4">

<div>

<h2 class="fw-bold">

Recruiter Dashboard

</h2>

<p class="text-muted">

Manage all your job postings in one place.

</p>

</div>

<input
type="text"
class="form-control"
placeholder="Search jobs..."
style="max-width:300px;">

</div>

<!-- Statistics -->

<div class="row mb-4">

<div class="col-md-4">

<div class="card stat-card">

<i class="fa-solid fa-briefcase text-primary"></i>

<h5>Total Jobs</h5>

<h2 class="text-primary">

<%= jobs.length %>

</h2>

</div>

</div>

<div class="col-md-4">

<div class="card stat-card">

<i class="fa-solid fa-users text-success"></i>

<h5>Total Applications</h5>

<h2 class="text-success">

120

</h2>

</div>

</div>

<div class="col-md-4">

<div class="card stat-card">

<i class="fa-solid fa-user-check text-warning"></i>

<h5>Shortlisted</h5>

<h2 class="text-warning">

35

</h2>

</div>

</div>

</div>

<div class="card">

<div class="card-body">

<% if(jobs.length===0){ %>

<div class="text-center p-5">

<i class="fa-solid fa-folder-open fa-4x text-secondary mb-3"></i>

<h4>No Jobs Posted</h4>

<p class="text-muted">

Click on <strong>Post Job</strong> to publish your first job.

</p>

<a href="/jobs/new" class="btn btn-primary">

Post First Job

</a>

</div>

<% }else{ %>

<div class="table-responsive">

<table class="table align-middle">

<thead class="table-dark">

<tr>

<th>Job Title</th>

<th>Company</th>

<th>Location</th>

<th>Salary</th>

<th>Actions</th>

</tr>

</thead>

<tbody>

<% jobs.forEach(job=>{ %>

<tr>

<td>

<strong>

<%= job.title %>

</strong>

</td>

<td>

<i class="fa-solid fa-building text-primary"></i>

<%= job.company %>

</td>

<td>

<i class="fa-solid fa-location-dot text-danger"></i>

<%= job.location %>

</td>

<td>

<span class="salary">

₹ <%= job.salary || "Not Mentioned" %>

</span>

</td>

<td>

<a
href="/jobs/<%= job._id %>"
class="btn btn-info btn-sm action-btn">

<i class="fa-solid fa-eye"></i>

View

</a>

<a
href="/jobs/<%= job._id %>/edit"
class="btn btn-warning btn-sm action-btn">

<i class="fa-solid fa-pen"></i>

Edit

</a>

<form
action="/jobs/<%= job._id %>?_method=DELETE"
method="POST"
style="display:inline;">

<button
class="btn btn-danger btn-sm"
onclick="return confirm('Delete this job?')">

<i class="fa-solid fa-trash"></i>

Delete

</button>

</form>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

<% } %>

</div>

</div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>