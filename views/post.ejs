<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Post New Job | Job Portal</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<style>

body{
    background:#f4f7fc;
}

/* Navbar */

.navbar{
    box-shadow:0 3px 10px rgba(0,0,0,.1);
}

/* Header */

.header{
    background:linear-gradient(135deg,#2563eb,#4f46e5);
    color:white;
    border-radius:20px;
    padding:40px;
    text-align:center;
    margin-bottom:30px;
}

/* Card */

.card{
    border:none;
    border-radius:20px;
    box-shadow:0 12px 30px rgba(0,0,0,.08);
}

/* Inputs */

.form-control,
.form-select{
    border-radius:12px;
    height:50px;
}

textarea.form-control{
    height:auto;
}

.form-control:focus,
.form-select:focus{
    box-shadow:0 0 10px rgba(13,110,253,.25);
}

/* Buttons */

.btn{
    border-radius:10px;
    height:48px;
}

/* Footer */

footer{
    color:gray;
    text-align:center;
    margin-top:40px;
    padding:20px;
}

</style>

</head>

<body>

<!-- Navbar -->

<nav class="navbar navbar-expand-lg navbar-dark bg-primary">

<div class="container">

<a class="navbar-brand fw-bold" href="/jobs">

<i class="fa-solid fa-briefcase me-2"></i>

Job Portal

</a>

<a href="/jobs" class="btn btn-light">

<i class="fa-solid fa-arrow-left"></i>

Back

</a>

</div>

</nav>

<div class="container py-5">

<!-- Header -->

<div class="header">

<h2>

<i class="fa-solid fa-plus-circle me-2"></i>

Post a New Job

</h2>

<p class="mb-0">

Create a professional job listing to hire the best candidates.

</p>

</div>

<div class="row justify-content-center">

<div class="col-lg-10">

<div class="card">

<div class="card-body p-5">

<form action="/jobs" method="POST">

<div class="row">

<!-- Job Title -->

<div class="col-md-6 mb-4">

<label class="form-label fw-semibold">

<i class="fa-solid fa-briefcase text-primary me-2"></i>

Job Title

</label>

<input
type="text"
class="form-control"
name="title"
placeholder="Frontend Developer"
required>

</div>

<!-- Company -->

<div class="col-md-6 mb-4">

<label class="form-label fw-semibold">

<i class="fa-solid fa-building text-primary me-2"></i>

Company Name

</label>

<input
type="text"
class="form-control"
name="company"
placeholder="Google"
required>

</div>

<!-- Logo -->

<div class="col-md-6 mb-4">

<label class="form-label fw-semibold">

<i class="fa-solid fa-image text-primary me-2"></i>

Company Logo URL

</label>

<input
type="text"
class="form-control"
name="logo"
placeholder="https://logo.png">

</div>

<!-- Location -->

<div class="col-md-6 mb-4">

<label class="form-label fw-semibold">

<i class="fa-solid fa-location-dot text-danger me-2"></i>

Location

</label>

<input
type="text"
class="form-control"
name="location"
placeholder="Bangalore">

</div>

<!-- Salary -->

<div class="col-md-6 mb-4">

<label class="form-label fw-semibold">

<i class="fa-solid fa-indian-rupee-sign text-success me-2"></i>

Salary

</label>

<input
type="number"
class="form-control"
name="salary"
placeholder="800000">

</div>

<!-- Experience -->

<div class="col-md-6 mb-4">

<label class="form-label fw-semibold">

<i class="fa-solid fa-user-clock text-primary me-2"></i>

Experience

</label>

<select class="form-select" name="experience">

<option>Fresher</option>
<option>1-2 Years</option>
<option>2-4 Years</option>
<option>5+ Years</option>

</select>

</div>

<!-- Job Type -->

<div class="col-md-6 mb-4">

<label class="form-label fw-semibold">

<i class="fa-solid fa-business-time text-primary me-2"></i>

Employment Type

</label>

<select class="form-select" name="jobType">

<option>Full Time</option>
<option>Part Time</option>
<option>Internship</option>
<option>Contract</option>

</select>

</div>

<!-- Mode -->

<div class="col-md-6 mb-4">

<label class="form-label fw-semibold">

<i class="fa-solid fa-laptop-house text-primary me-2"></i>

Work Mode

</label>

<select class="form-select" name="mode">

<option>On-site</option>
<option>Remote</option>
<option>Hybrid</option>

</select>

</div>

<!-- Qualification -->

<div class="col-md-6 mb-4">

<label class="form-label fw-semibold">

<i class="fa-solid fa-graduation-cap text-primary me-2"></i>

Qualification

</label>

<input
type="text"
class="form-control"
name="qualification"
placeholder="B.Tech / MCA">

</div>

<!-- Deadline -->

<div class="col-md-6 mb-4">

<label class="form-label fw-semibold">

<i class="fa-solid fa-calendar text-primary me-2"></i>

Application Deadline

</label>

<input
type="date"
class="form-control"
name="deadline">

</div>

<!-- Skills -->

<div class="col-12 mb-4">

<label class="form-label fw-semibold">

<i class="fa-solid fa-code text-primary me-2"></i>

Required Skills

</label>

<input
type="text"
class="form-control"
name="skills"
placeholder="React, Node.js, MongoDB">

</div>

<!-- Description -->

<div class="col-12 mb-4">

<label class="form-label fw-semibold">

<i class="fa-solid fa-file-lines text-primary me-2"></i>

Job Description

</label>

<textarea
class="form-control"
rows="6"
id="description"
name="description"
placeholder="Describe responsibilities, requirements and benefits..."
required></textarea>

<small id="counter" class="text-muted">
0 characters
</small>

</div>

<!-- Buttons -->

<div class="text-end">

<a href="/jobs" class="btn btn-secondary px-4">

<i class="fa-solid fa-arrow-left me-2"></i>

Cancel

</a>

<button class="btn btn-primary px-5">

<i class="fa-solid fa-paper-plane me-2"></i>

Publish Job

</button>

</div>

</div>

</form>

</div>

</div>

</div>

</div>

<footer>

© 2026 Job Portal | Built with Node.js, Express & MongoDB

</footer>

</div>

<script>

const textarea=document.getElementById("description");
const counter=document.getElementById("counter");

textarea.addEventListener("input",function(){

counter.innerText=this.value.length+" characters";

});

</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>