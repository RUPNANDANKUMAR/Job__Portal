<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Manage Jobs | Job Portal</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<style>

body{
    background:#f5f7fb;
}

.navbar{
    box-shadow:0 2px 10px rgba(0,0,0,.1);
}

.dashboard-card{
    border:none;
    border-radius:15px;
    box-shadow:0 5px 20px rgba(0,0,0,.08);
}

.table{
    vertical-align:middle;
}

.table tbody tr:hover{
    background:#eef5ff;
}

.badge-salary{
    background:#198754;
    color:white;
    font-size:14px;
    padding:8px 12px;
    border-radius:20px;
}

.action-btn{
    margin-right:5px;
}

.search-box{
    max-width:350px;
}

</style>

</head>

<body>

<!-- Navbar -->

<nav class="navbar navbar-expand-lg navbar-dark bg-primary">

<div class="container">

<a class="navbar-brand fw-bold" href="/home">

<i class="fa-solid fa-briefcase"></i>

Job Portal

</a>

<div>

<a href="/jobs/new" class="btn btn-light">

<i class="fa-solid fa-plus"></i>

Post Job

</a>

</div>

</div>

</nav>

<div class="container mt-5">

<div class="d-flex justify-content-between align-items-center mb-4">

<div>

<h2 class="fw-bold">

Recruiter Dashboard

</h2>

<p class="text-muted">

Manage all your posted jobs.

</p>

</div>

<input
type="text"
class="form-control search-box"
placeholder="Search Job...">

</div>

<!-- Statistics -->

<div class="row mb-4">

<div class="col-md-4">

<div class="card dashboard-card">

<div class="card-body text-center">

<h6>Total Jobs</h6>

<h2 class="text-primary">

<%= jobs.length %>

</h2>

</div>

</div>

</div>

<div class="col-md-4">

<div class="card dashboard-card">

<div class="card-body text-center">

<h6>Active Jobs</h6>

<h2 class="text-success">

<%= jobs.length %>

</h2>

</div>

</div>

</div>

<div class="col-md-4">

<div class="card dashboard-card">

<div class="card-body text-center">

<h6>Recruiter</h6>

<h2 class="text-warning">

👨‍💼

</h2>

</div>

</div>

</div>

</div>

<!-- Table -->

<div class="card dashboard-card">

<div class="card-body">

<% if(jobs.length===0){ %>

<div class="text-center p-5">

<i class="fa-solid fa-folder-open fa-4x text-secondary mb-3"></i>

<h4>No Jobs Posted Yet</h4>

<p class="text-muted">

Click "Post Job" to create your first job.

</p>

</div>

<% } else { %>

<div class="table-responsive">

<table class="table table-hover">

<thead class="table-dark">

<tr>

<th>Job Title</th>

<th>Company</th>

<th>Location</th>

<th>Salary</th>

<th width="240">Actions</th>

</tr>

</thead>

<tbody>

<% jobs.forEach(job=>{ %>

<tr>

<td>

<strong>

<%= job.title %>

</strong>

</td>

<td>

<%= job.company %>

</td>

<td>

<i class="fa-solid fa-location-dot text-danger"></i>

<%= job.location %>

</td>

<td>

<span class="badge-salary">

₹ <%= job.salary %>

</span>

</td>

<td>

<a href="/jobs/<%= job._id %>"

class="btn btn-info btn-sm action-btn">

<i class="fa-solid fa-eye"></i>

View

</a>

<a href="/jobs/<%= job._id %>/edit"

class="btn btn-warning btn-sm action-btn">

<i class="fa-solid fa-pen"></i>

Edit

</a>

<form
action="/jobs/<%= job._id %>?_method=DELETE"
method="POST"
style="display:inline;">

<button
class="btn btn-danger btn-sm">

<i class="fa-solid fa-trash"></i>

Delete

</button>

</form>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

<% } %>

</div>

</div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>